# core service configuration. Copy to .env for local development; in
# production these come from the real environment or a secret manager.

APP_ENV=development
APP_NAME=core
GRPC_PORT=50051
METRICS_PORT=9091

# Primary (read-write) database. Required.
DB_WRITE_URL=postgres://lynk:lynk@localhost:5432/core_db?sslmode=disable
# Comma-separated read replicas; empty = reads hit the primary.
DB_READ_URLS=
#DB_MAX_CONNS=0
#DB_MIN_CONNS=5
#DB_MAX_CONN_LIFETIME=30m
#DB_MAX_CONN_IDLE_TIME=5m

REDIS_URL=redis://localhost:6379/0
NATS_URL=nats://localhost:4222
#NATS_STREAM_REPLICAS=1

# RS256 keys (PEM). Required in production; optional in development.
# Generate: openssl genrsa -out jwt_priv.pem 2048
#           openssl rsa -in jwt_priv.pem -pubout -out jwt_pub.pem
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=
JWT_ISSUER=lynk
#JWT_ACCESS_TTL=15m
#JWT_REFRESH_TTL=168h

LOG_LEVEL=info
LOG_JSON=false

OTEL_ENABLED=false
OTEL_ENDPOINT=localhost:4317
OTEL_TRACE_SAMPLE_RATIO=1.0

# Internal mTLS (server side): set all three to require client certs.
#GRPC_TLS_CERT_FILE=
#GRPC_TLS_KEY_FILE=
#GRPC_TLS_CLIENT_CA_FILE=
