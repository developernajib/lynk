# gateway configuration. Copy to .env for local development.

APP_ENV=development
APP_NAME=gateway
HTTP_PORT=8080
METRICS_PORT=9090

REDIS_URL=redis://localhost:6379/0
UPSTREAM_CORE=localhost:50051

# Exact-match CORS origin allowlist (comma-separated).
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000

RATE_LIMIT_GLOBAL_PER_SECOND=10000
RATE_LIMIT_PER_IP_PER_MINUTE=600

# RS256 PUBLIC key (PEM). Must match core's signer; required in production.
JWT_PUBLIC_KEY_PEM=
JWT_ISSUER=lynk

LOG_LEVEL=info
LOG_JSON=false

OTEL_ENABLED=false
OTEL_ENDPOINT=localhost:4317
OTEL_TRACE_SAMPLE_RATIO=1.0

# Public TLS termination at the gateway (leave empty behind a TLS proxy).
#HTTP_TLS_CERT_FILE=
#HTTP_TLS_KEY_FILE=

# Internal mTLS to backends (client side): all three or none.
#INTERNAL_TLS_CERT_FILE=
#INTERNAL_TLS_KEY_FILE=
#INTERNAL_TLS_CA_FILE=
